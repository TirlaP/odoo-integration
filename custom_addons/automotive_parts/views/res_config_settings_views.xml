<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_automotive" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.automotive</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='quotation_order_setting_container']" position="inside">
                <setting id="automotive_ready_notification_setting"
                         string="Order Ready Notifications"
                         help="Create in-app activities and optionally email the customer when an order becomes ready for preparation.">
                    <field name="automotive_ready_email_enabled"/>
                    <div class="content-group" invisible="not automotive_ready_email_enabled">
                        <div class="mt8">
                            <label for="automotive_ready_email_template_id" class="o_light_label me-2"/>
                            <field name="automotive_ready_email_template_id" options="{'no_create': True}"/>
                        </div>
                    </div>
                </setting>
                <setting id="automotive_label_direct_print_setting"
                         string="Direct Label Printing"
                         help="Send automotive label PDFs directly from the Odoo server to a configured printer using lp or lpr.">
                    <field name="automotive_label_direct_print_enabled"/>
                    <div class="content-group" invisible="not automotive_label_direct_print_enabled">
                        <div class="mt8">
                            <label for="automotive_label_printer_name" class="o_light_label me-2"/>
                            <field name="automotive_label_printer_name" placeholder="printer_queue_name"/>
                        </div>
                        <div class="mt8">
                            <label for="automotive_label_print_command" class="o_light_label me-2"/>
                            <field name="automotive_label_print_command" placeholder="lp"/>
                        </div>
                        <div class="mt8">
                            <label for="automotive_label_default_copies" class="o_light_label me-2"/>
                            <field name="automotive_label_default_copies"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
