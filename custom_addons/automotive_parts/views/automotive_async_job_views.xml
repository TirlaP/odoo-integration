<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_automotive_async_job_search" model="ir.ui.view">
        <field name="name">automotive.async.job.search</field>
        <field name="model">automotive.async.job</field>
        <field name="arch" type="xml">
            <search string="Background Jobs">
                <field name="name"/>
                <field name="job_type"/>
                <field name="state"/>
                <field name="reference_model"/>
                <field name="reference_res_id"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <filter string="Queued" name="queued" domain="[('state', '=', 'queued')]"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'job_type'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Requested By" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Batch" name="group_batch" context="{'group_by': 'batch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_automotive_async_job_tree" model="ir.ui.view">
        <field name="name">automotive.async.job.tree</field>
        <field name="model">automotive.async.job</field>
        <field name="arch" type="xml">
            <list string="Background Jobs" create="0" edit="0" delete="0" default_order="priority desc, scheduled_at asc, id desc">
                <field name="scheduled_at"/>
                <field name="name"/>
                <field name="job_type"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="batch_id" optional="show"/>
                <field name="progress_percent" widget="progressbar" optional="show"/>
                <field name="attempt_count"/>
                <field name="max_attempts"/>
                <field name="user_id" optional="show"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_automotive_async_job_form" model="ir.ui.view">
        <field name="name">automotive.async.job.form</field>
        <field name="model">automotive.async.job</field>
        <field name="arch" type="xml">
            <form string="Background Job">
                <header>
                    <button name="action_retry" type="object" string="Retry" class="btn-primary"
                            invisible="state not in ('failed', 'cancelled')" groups="base.group_system"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"
                            invisible="state not in ('queued', 'failed')" groups="base.group_system"/>
                    <button name="action_view_reference" type="object" string="Open Source" class="btn-secondary" invisible="not reference_model or not reference_res_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="queued,running,done,failed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="job_type"/>
                            <field name="batch_id"/>
                            <field name="priority"/>
                            <field name="scheduled_at"/>
                        </group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="attempt_count" readonly="1"/>
                            <field name="max_attempts"/>
                        </group>
                    </group>
                    <group string="Execution">
                        <group>
                            <field name="handler_model" readonly="1"/>
                            <field name="handler_method" readonly="1"/>
                            <field name="reference_model" readonly="1"/>
                            <field name="reference_res_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                            <field name="progress_current" readonly="1"/>
                            <field name="progress_total" readonly="1"/>
                            <field name="progress_percent" widget="progressbar" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Result">
                            <group>
                                <field name="result_message" readonly="1"/>
                                <field name="last_error" readonly="1"/>
                            </group>
                        </page>
                        <page string="Payload">
                            <field name="payload_json" readonly="1" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_automotive_async_batch_search" model="ir.ui.view">
        <field name="name">automotive.async.batch.search</field>
        <field name="model">automotive.async.batch</field>
        <field name="arch" type="xml">
            <search string="Background Batches">
                <field name="name"/>
                <field name="job_type"/>
                <field name="state"/>
                <field name="user_id"/>
                <field name="company_id"/>
            </search>
        </field>
    </record>

    <record id="view_automotive_async_batch_tree" model="ir.ui.view">
        <field name="name">automotive.async.batch.tree</field>
        <field name="model">automotive.async.batch</field>
        <field name="arch" type="xml">
            <list string="Background Batches" create="0" edit="0" delete="0" default_order="create_date desc, id desc">
                <field name="create_date"/>
                <field name="name"/>
                <field name="job_type"/>
                <field name="state"/>
                <field name="total_jobs"/>
                <field name="done_jobs"/>
                <field name="failed_jobs"/>
                <field name="progress_percent" widget="progressbar"/>
                <field name="user_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_automotive_async_batch_form" model="ir.ui.view">
        <field name="name">automotive.async.batch.form</field>
        <field name="model">automotive.async.batch</field>
        <field name="arch" type="xml">
            <form string="Background Batch">
                <header>
                    <button name="action_view_jobs" type="object" string="Open Jobs" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="queued,running,partial,done,failed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="job_type"/>
                            <field name="user_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_jobs" readonly="1"/>
                            <field name="queued_jobs" readonly="1"/>
                            <field name="running_jobs" readonly="1"/>
                            <field name="done_jobs" readonly="1"/>
                            <field name="failed_jobs" readonly="1"/>
                            <field name="progress_percent" widget="progressbar" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <field name="job_ids" readonly="1" nolabel="1">
                        <list create="0" edit="0" delete="0">
                            <field name="scheduled_at"/>
                            <field name="name"/>
                            <field name="job_type"/>
                            <field name="state"/>
                            <field name="progress_percent" widget="progressbar"/>
                            <field name="attempt_count"/>
                            <field name="result_message"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_automotive_async_jobs" model="ir.actions.act_window">
        <field name="name">Background Jobs</field>
        <field name="path">automotive-background-jobs</field>
        <field name="res_model">automotive.async.job</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_automotive_async_job_search"/>
    </record>

    <record id="action_automotive_async_batches" model="ir.actions.act_window">
        <field name="name">Background Batches</field>
        <field name="path">automotive-background-batches</field>
        <field name="res_model">automotive.async.batch</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_automotive_async_batch_search"/>
    </record>
</odoo>
