    <!-- TecDoc Fast: Article Variants -->
    <record id="view_tecdoc_article_variant_search" model="ir.ui.view">
        <field name="name">tecdoc.article.variant.search</field>
        <field name="model">tecdoc.article.variant</field>
        <field name="arch" type="xml">
            <search string="TecDoc Variants">
                <field name="name"/>
                <field name="article_no"/>
                <field name="supplier_name"/>
                <field name="supplier_external_id"/>
                <field name="product_tmpl_id"/>
                <filter string="Has Vehicles" name="has_vehicles" domain="[('vehicle_count','&gt;',0)]"/>
                <filter string="Has OEM" name="has_oem" domain="[('oem_count','&gt;',0)]"/>
                <filter string="Has Cross" name="has_cross" domain="[('cross_count','&gt;',0)]"/>
            </search>
        </field>
    </record>

    <record id="view_tecdoc_article_variant_list" model="ir.ui.view">
        <field name="name">tecdoc.article.variant.list</field>
        <field name="model">tecdoc.article.variant</field>
        <field name="arch" type="xml">
            <list string="TecDoc Variants">
                <field name="name"/>
                <field name="article_id"/>
                <field name="article_no"/>
                <field name="supplier_name"/>
                <field name="article_product_name"/>
                <field name="vehicle_count"/>
                <field name="oem_count"/>
                <field name="criteria_count"/>
                <field name="cross_count"/>
                <field name="ean_count"/>
                <field name="product_tmpl_id"/>
            </list>
        </field>
    </record>

    <record id="view_tecdoc_article_variant_form" model="ir.ui.view">
        <field name="name">tecdoc.article.variant.form</field>
        <field name="model">tecdoc.article.variant</field>
        <field name="arch" type="xml">
            <form string="TecDoc Variant">
                <header>
                    <button name="action_enrich_reference" type="object" string="Enrich TecDoc" class="btn-secondary"/>
                    <button name="action_create_product_from_reference" type="object" string="Creează produs" class="btn-primary" invisible="product_tmpl_id"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_vehicles" type="object" class="oe_stat_button" icon="fa-car"
                                invisible="not vehicle_count">
                            <field name="vehicle_count" widget="statinfo" string="Vehicles"/>
                        </button>
                        <button name="action_open_oem_numbers" type="object" class="oe_stat_button" icon="fa-barcode"
                                invisible="not oem_count">
                            <field name="oem_count" widget="statinfo" string="OEM"/>
                        </button>
                        <button name="action_open_specs" type="object" class="oe_stat_button" icon="fa-list"
                                invisible="not criteria_count">
                            <field name="criteria_count" widget="statinfo" string="Specs"/>
                        </button>
                        <button name="action_open_cross_refs" type="object" class="oe_stat_button" icon="fa-random"
                                invisible="not cross_count">
                            <field name="cross_count" widget="statinfo" string="Cross"/>
                        </button>
                        <button name="action_open_eans" type="object" class="oe_stat_button" icon="fa-qrcode"
                                invisible="not ean_count">
                            <field name="ean_count" widget="statinfo" string="EAN"/>
                        </button>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="name" readonly="1"/>
                            <field name="article_id"/>
                            <field name="article_no"/>
                            <field name="identity_key" readonly="1"/>
                            <field name="is_reference_only" readonly="1"/>
                            <field name="last_enriched_at" readonly="1"/>
                            <field name="supplier_id"/>
                            <field name="supplier_name"/>
                            <field name="supplier_external_id"/>
                            <field name="product_tmpl_id"/>
                        </group>
                        <group string="Media">
                            <field name="image_url" widget="url"/>
                            <field name="media_type"/>
                            <field name="media_filename"/>
                        </group>
                    </group>
                    <group string="Product">
                        <field name="article_product_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

