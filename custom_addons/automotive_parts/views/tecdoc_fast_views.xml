<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- TecDoc Fast: Import Runs -->
    <record id="view_tecdoc_fast_import_run_list" model="ir.ui.view">
        <field name="name">tecdoc.fast.import.run.list</field>
        <field name="model">tecdoc.fast.import.run</field>
        <field name="arch" type="xml">
            <list string="TecDoc Fast Import Runs">
                <field name="name"/>
                <field name="state"/>
                <field name="directory"/>
                <field name="cursor"/>
                <field name="batch_size"/>
                <field name="processed"/>
                <field name="created_products"/>
                <field name="created_variants"/>
                <field name="updated_variants"/>
                <field name="started_at"/>
                <field name="finished_at"/>
            </list>
        </field>
    </record>

    <record id="view_tecdoc_fast_import_run_form" model="ir.ui.view">
        <field name="name">tecdoc.fast.import.run.form</field>
        <field name="model">tecdoc.fast.import.run</field>
        <field name="arch" type="xml">
            <form string="TecDoc Fast Import Run">
                <header>
                    <button name="action_start" string="Start" type="object" class="btn-primary"
                            invisible="state not in ('draft','failed')"/>
                    <button name="action_reset" string="Reset" type="object" class="btn-secondary"
                            invisible="state not in ('failed','done')"/>
                    <button name="action_open_purge_wizard" string="Purge Fast Data" type="object" class="btn-secondary"
                            invisible="state == 'running'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,running,done,failed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Input">
                            <field name="name"/>
                            <field name="directory" placeholder="/path/to/tecdoc_data/..."/>
                            <field name="batch_size"/>
                            <field name="run_mode"/>
                            <field name="replace_variant_details"/>
                            <field name="import_cross_references"/>
                            <field name="mark_products_managed"/>
                        </group>
                        <group string="Progress">
                            <field name="cursor"/>
                            <field name="processed"/>
                            <field name="created_products"/>
                            <field name="created_variants"/>
                            <field name="updated_variants"/>
                            <field name="created_vehicles"/>
                            <field name="created_oem_numbers"/>
                            <field name="created_cross_numbers"/>
                            <field name="started_at"/>
                            <field name="finished_at"/>
                        </group>
                    </group>
                    <group string="Error" invisible="state != 'failed'">
                        <field name="last_error" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tecdoc_fast_import_runs" model="ir.actions.act_window">
        <field name="name">Import rapid TecDoc</field>
        <field name="path">import-rapid-tecdoc</field>
        <field name="res_model">tecdoc.fast.import.run</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- TecDoc Fast: Purge Wizard -->
    <record id="view_tecdoc_fast_purge_wizard_form" model="ir.ui.view">
        <field name="name">tecdoc.fast.purge.wizard.form</field>
        <field name="model">tecdoc.fast.purge.wizard</field>
        <field name="arch" type="xml">
            <form string="Purge TecDoc Fast Data">
                <sheet>
                    <group>
                        <field name="run_id" readonly="1"/>
                    </group>
                    <group string="What to purge">
                        <field name="purge_fast_tables"/>
                    </group>
                    <group string="Products">
                        <field name="product_scope"/>
                        <field name="product_action"/>
                    </group>
                    <group string="Confirmation">
                        <label for="confirmation"/>
                        <div>
                            <field name="confirmation" placeholder="Type DELETE to confirm..."/>
                        </div>
                    </group>
                    <group>
                        <p>
                            This action is destructive. Recommended: choose "Archive Products" unless you are sure.
                        </p>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Purge" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

