        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_product_template_search_tecdoc_fast"/>
        <field name="domain">[('tecdoc_variant_ids','!=',False)]</field>
    </record>

    <!-- Product Template: TecDoc Fast tab -->
    <record id="view_product_template_form_tecdoc_fast" model="ir.ui.view">
        <field name="name">product.template.form.tecdoc.fast</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="automotive_parts.view_product_template_form_automotive"/>
        <field name="arch" type="xml">
            <!-- Merge "Fast" info into the existing TecDoc Integration tab to avoid multiple TecDoc tabs -->
            <xpath expr="//page[@name='tecdoc']" position="inside">
                <separator string="Catalog Data (preloaded)" colspan="4"/>
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_tecdoc_variants" type="object" class="oe_stat_button" icon="fa-cubes"
                            invisible="not tecdoc_variant_count">
                        <field name="tecdoc_variant_count" widget="statinfo" string="Variants"/>
                    </button>
                </div>
                <group string="Keys">
                    <field name="tecdoc_article_no" string="Article No (system)" readonly="1" invisible="1"/>
                    <field name="tecdoc_article_no_key" readonly="1" invisible="1"/>
                </group>
                <group string="Variants (by supplier)">
                    <field name="tecdoc_variant_ids" nolabel="1">
                        <list>
                            <field name="supplier_name"/>
                            <field name="article_product_name"/>
                            <field name="vehicle_count"/>
                            <field name="oem_count"/>
                            <field name="criteria_count"/>
                            <field name="cross_count"/>
                            <field name="ean_count"/>
                        </list>
                    </field>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
