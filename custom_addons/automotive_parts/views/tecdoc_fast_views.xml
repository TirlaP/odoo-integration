    <!-- TecDoc Fast: Product search action with TecDoc lookup field -->
    <record id="view_product_template_search_tecdoc_fast" model="ir.ui.view">
        <field name="name">product.template.search.tecdoc.fast</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search string="Products (TecDoc Fast)">
                <field name="name"/>
                <field name="default_code"/>
                <field name="barcode"/>
                <field name="tecdoc_article_no"/>
                <field name="tecdoc_lookup" string="TecDoc Lookup"/>
                <filter string="Has Variants" name="has_variants" domain="[('tecdoc_variant_ids','!=',False)]"/>
            </search>
        </field>
