<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Forward declarations for action buttons used in the first form view. -->
    <record id="action_tecdoc_api_cache" model="ir.actions.act_window">
        <field name="name">Cache TecDoc</field>
        <field name="res_model">tecdoc.api.cache</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_tecdoc_products" model="ir.actions.act_window">
        <field name="name">Produse TecDoc</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- TecDoc API Configuration Form -->
    <record id="view_tecdoc_api_form" model="ir.ui.view">
        <field name="name">tecdoc.api.form</field>
        <field name="model">tecdoc.api</field>
        <field name="arch" type="xml">
            <form string="TecDoc API Configuration">
                <header>
                    <button name="action_use_auto_parts_catalog" string="Use Auto Parts Catalog" type="object" class="btn-primary"/>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    <button name="action_sync_suppliers_catalog" string="Sync TecDoc Suppliers" type="object" class="btn-secondary"/>
                    <button name="%(action_tecdoc_api_cache)d" string="Open Cache" type="action" class="btn-secondary"/>
                    <button name="%(action_tecdoc_products)d" string="Review TecDoc Products" type="action" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="api_key">
                        RapidAPI key is missing. TecDoc sync/search actions will fail until the key is configured.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="cache_enabled">
                        Cache is disabled. This removes the local safety net and makes TecDoc calls fully dependent on the live API.
                    </div>
                    <div class="alert alert-info" role="alert">
                        Treat TecDoc as the reference source for article compatibility and supplier metadata.
                        Products without a TecDoc link should be considered manually maintained.
                    </div>
                    <group>
                        <group string="API Configuration">
                            <field name="name"/>
                            <field name="provider"/>
                            <field name="is_default"/>
                            <field name="api_key" password="True"/>
                            <field name="api_host"/>
                            <field name="base_url"/>
                        </group>
                        <group string="Default Settings">
                            <field name="lang_id"/>
                            <field name="country_filter_id"/>
                            <field name="cache_enabled"/>
                            <field name="cache_ttl_seconds" invisible="not cache_enabled"/>
                            <field name="cache_allow_stale_on_error" invisible="not cache_enabled"/>
                            <field name="download_images"/>
                            <field name="overwrite_images" invisible="not download_images"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Governance &amp; Status" name="governance_status">
                            <group>
                                <group string="Governance">
                                    <div class="o_form_label">Source of truth</div>
                                    <div>
                                        <p class="text-muted">
                                            TecDoc-linked products should keep supplier/article compatibility aligned with TecDoc.
                                            Manual products can still exist, but they should be reviewed separately.
                                        </p>
                                    </div>
                                    <div class="o_form_label">Operator rules</div>
                                    <div>
                                        <ul class="mb0">
                                            <li>Keep cache enabled in production.</li>
                                            <li>Use stale cache fallback to reduce outage impact.</li>
                                            <li>Review TecDoc-linked products after supplier sync changes.</li>
                                        </ul>
                                    </div>
                                </group>
                                <group string="Current Status">
                                    <field name="cache_enabled" widget="boolean_toggle"/>
                                    <field name="cache_allow_stale_on_error" widget="boolean_toggle" invisible="not cache_enabled"/>
                                    <field name="cache_ttl_seconds" invisible="not cache_enabled"/>
                                    <field name="download_images" widget="boolean_toggle"/>
                                    <field name="overwrite_images" invisible="not download_images"/>
                                    <field name="lang_id"/>
                                    <field name="country_filter_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Help" name="help">
                            <group>
                                <div>
                                    <h3>TecDoc API Setup Instructions</h3>
                                    <ol>
                                        <li>Sign up for RapidAPI at https://rapidapi.com</li>
                                        <li>Subscribe to Auto Parts Catalog API</li>
                                        <li>Copy your API key from RapidAPI dashboard</li>
                                        <li>Paste it in the API Key field above</li>
                                        <li>Save this configuration</li>
                                    </ol>

                                    <p><strong>Language IDs:</strong></p>
                                    <ul>
                                        <li>Use the RapidAPI “Languages” endpoint to list valid IDs for your plan.</li>
                                        <li>Provider examples often use <code>lang_id = 4</code>.</li>
                                    </ul>

                                    <p><strong>Country Filter IDs:</strong></p>
                                    <ul>
                                        <li>Use the RapidAPI “Countries” / “Country details” endpoints to find the correct country filter id.</li>
                                        <li>Provider examples often use <code>country_filter_id = 63</code>.</li>
                                    </ul>

                                    <p><strong>Debugging requests:</strong></p>
                                    <ul>
                                        <li>Open <em>Automotive Parts → TecDoc → Cache</em> to see the exact endpoint/params and the raw JSON response saved by the module.</li>
                                    </ul>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- TecDoc API Tree -->
    <record id="view_tecdoc_api_tree" model="ir.ui.view">
        <field name="name">tecdoc.api.tree</field>
        <field name="model">tecdoc.api</field>
        <field name="arch" type="xml">
            <list string="TecDoc API"
                  decoration-warning="cache_enabled == False"
                  decoration-info="download_images == True">
                <field name="name"/>
                <field name="provider"/>
                <field name="is_default"/>
                <field name="api_host"/>
                <field name="lang_id"/>
                <field name="cache_enabled"/>
                <field name="cache_allow_stale_on_error" optional="hide"/>
                <field name="download_images" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_tecdoc_api_search" model="ir.ui.view">
        <field name="name">tecdoc.api.search</field>
        <field name="model">tecdoc.api</field>
        <field name="arch" type="xml">
            <search string="TecDoc API Configuration">
                <field name="name"/>
                <field name="provider"/>
                <field name="api_host"/>
                <field name="lang_id"/>
                <field name="country_filter_id"/>
                <filter string="Default Lookup" name="default_lookup" domain="[('is_default', '=', True)]"/>
                <filter string="Cache Enabled" name="cache_enabled" domain="[('cache_enabled', '=', True)]"/>
                <filter string="Cache Disabled" name="cache_disabled" domain="[('cache_enabled', '=', False)]"/>
                <filter string="Download Images" name="download_images" domain="[('download_images', '=', True)]"/>
                <filter string="No API Key" name="no_api_key" domain="[('api_key', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="API Host" name="group_api_host" context="{'group_by': 'api_host'}"/>
                    <filter string="Provider" name="group_provider" context="{'group_by': 'provider'}"/>
                    <filter string="Language" name="group_lang" context="{'group_by': 'lang_id'}"/>
                    <filter string="Country" name="group_country" context="{'group_by': 'country_filter_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- TecDoc API Action -->
    <record id="action_tecdoc_api" model="ir.actions.act_window">
        <field name="name">TecDoc API Configuration</field>
        <field name="path">automotive-tecdoc-config</field>
        <field name="res_model">tecdoc.api</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tecdoc_api_search"/>
    </record>

    <!-- TecDoc Cache List -->
    <record id="view_tecdoc_api_cache_list" model="ir.ui.view">
        <field name="name">tecdoc.api.cache.list</field>
        <field name="model">tecdoc.api.cache</field>
        <field name="arch" type="xml">
            <list string="TecDoc Cache" create="false" delete="false"
                  decoration-danger="ok == False"
                  decoration-info="hits &gt; 0">
                <field name="api_id"/>
                <field name="method" optional="hide"/>
                <field name="endpoint"/>
                <field name="ok"/>
                <field name="status_code"/>
                <field name="hits"/>
                <field name="fetched_at"/>
                <field name="expires_at"/>
                <field name="last_hit_at"/>
            </list>
        </field>
    </record>

    <record id="view_tecdoc_api_cache_form" model="ir.ui.view">
        <field name="name">tecdoc.api.cache.form</field>
        <field name="model">tecdoc.api.cache</field>
        <field name="arch" type="xml">
            <form string="TecDoc Cache Entry" create="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="api_id" readonly="1"/>
                            <field name="endpoint" readonly="1"/>
                            <field name="params_json" widget="text" readonly="1"/>
                        </group>
                        <group>
                            <field name="ok" readonly="1"/>
                            <field name="status_code" readonly="1"/>
                            <field name="hits" readonly="1"/>
                            <field name="fetched_at" readonly="1"/>
                            <field name="expires_at" readonly="1"/>
                            <field name="last_hit_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Error" invisible="ok">
                        <field name="error" widget="text" readonly="1"/>
                    </group>
                    <group string="Response">
                        <field name="response_json" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tecdoc_api_cache_search" model="ir.ui.view">
        <field name="name">tecdoc.api.cache.search</field>
        <field name="model">tecdoc.api.cache</field>
        <field name="arch" type="xml">
            <search string="TecDoc Cache">
                <field name="api_id"/>
                <field name="endpoint"/>
                <field name="status_code"/>
                <filter string="Healthy" name="healthy" domain="[('ok', '=', True)]"/>
                <filter string="Errors" name="errors" domain="[('ok', '=', False)]"/>
                <filter string="Used Entries" name="used_entries" domain="[('hits', '&gt;', 0)]"/>
                <filter string="Freshly Fetched" name="recent_fetch" domain="[('fetched_at', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="API" name="group_api" context="{'group_by': 'api_id'}"/>
                    <filter string="Endpoint" name="group_endpoint" context="{'group_by': 'endpoint'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'ok'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tecdoc_api_cache" model="ir.actions.act_window">
        <field name="name">Cache TecDoc</field>
        <field name="path">cache-tecdoc</field>
        <field name="res_model">tecdoc.api.cache</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_tecdoc_api_cache_search"/>
    </record>

    <!-- TecDoc Products (synced) -->
    <record id="action_tecdoc_products" model="ir.actions.act_window">
        <field name="name">Produse TecDoc</field>
        <field name="path">produse-tecdoc</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['|', ('tecdoc_id', '!=', False), ('tecdoc_article_no', '!=', False)]</field>
        <field name="context">{}</field>
    </record>

    <!-- TecDoc Sync Wizard -->
    <record id="view_tecdoc_sync_wizard_form" model="ir.ui.view">
        <field name="name">tecdoc.sync.wizard.form</field>
        <field name="model">tecdoc.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Sincronizare produs din TecDoc">
                <group>
                    <field name="lookup_type"/>
                    <field name="article_number" placeholder="Introdu codul articolului..."/>
                    <field name="supplier_id"/>
                    <field name="invoice_ingest_line_id" invisible="1"/>
                </group>
                <group>
                    <field name="candidates_info" widget="text" readonly="1" placeholder="Apasă „Găsește furnizori” pentru a previzualiza potrivirile."/>
                </group>
                <footer>
                    <button name="action_preview_candidates" string="Găsește furnizori" type="object" class="btn-secondary"/>
                    <button name="action_sync" string="Sincronizează produsul" type="object" class="btn-primary"/>
                    <button string="Anulează" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- TecDoc Sync Wizard Action -->
    <record id="action_tecdoc_sync_wizard" model="ir.actions.act_window">
        <field name="name">Sincronizare produs TecDoc</field>
        <field name="path">sincronizare-tecdoc</field>
        <field name="res_model">tecdoc.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ANAF e-Factura Configuration Form -->
    <record id="view_anaf_efactura_form" model="ir.ui.view">
        <field name="name">anaf.efactura.form</field>
        <field name="model">anaf.efactura</field>
        <field name="arch" type="xml">
            <form string="ANAF e-Factura Configuration">
                <header>
                    <button name="action_load_from_env" string="Load from Env" type="object" class="btn-secondary"/>
                    <button name="action_open_authorize_url" string="Open OAuth Login" type="object" class="btn-secondary"
                            invisible="use_oauth == False"/>
                    <button name="action_exchange_authorization_code" string="Exchange Auth Code" type="object" class="btn-primary"
                            invisible="use_oauth == False"/>
                    <button name="action_refresh_access_token" string="Refresh Access Token" type="object" class="btn-secondary"
                            invisible="use_oauth == False"/>
                    <button name="fetch_invoices" string="Fetch Invoices" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Base Configuration">
                            <field name="name"/>
                            <field name="active"/>
                            <field name="environment"/>
                            <field name="cui_company"/>
                            <field name="use_oauth"/>
                            <field name="api_url"/>
                            <field name="api_token" password="True" invisible="use_oauth == True"/>
                        </group>
                        <group string="Fetch Controls">
                            <field name="fetch_days"/>
                            <field name="fetch_filter"/>
                            <field name="last_sync_at" readonly="1"/>
                            <field name="last_fetch_count" readonly="1"/>
                        </group>
                    </group>

                    <group string="OAuth2 Settings" invisible="use_oauth == False">
                        <group>
                            <field name="oauth_authorize_url"/>
                            <field name="oauth_token_url"/>
                            <field name="oauth_client_id"/>
                            <field name="oauth_client_secret" password="True"/>
                            <field name="oauth_redirect_uri"/>
                            <field name="oauth_token_content_type"/>
                        </group>
                        <group>
                            <field name="oauth_state" readonly="1"/>
                            <field name="oauth_authorization_code" placeholder="Paste authorization code from redirect URL"/>
                            <field name="access_token" password="True"/>
                            <field name="refresh_token" password="True"/>
                            <field name="token_expires_at" readonly="1"/>
                            <field name="refresh_expires_at" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Help" name="help">
                            <group>
                                <div>
                                    <h3>ANAF e-Factura Setup Instructions</h3>
                                    <p>OAuth2 endpoints (ANAF official):</p>
                                    <ul>
                                        <li>Authorize: https://logincert.anaf.ro/anaf-oauth2/v1/authorize</li>
                                        <li>Token: https://logincert.anaf.ro/anaf-oauth2/v1/token</li>
                                    </ul>
                                    <p>Use "Load from Env" to populate fields from environment variables.</p>
                                    <p>This flow fetches messages via listaMesajeFactura and downloads XML via descarcare.</p>
                                </div>
                            </group>
                        </page>
                        <page string="Sync Status">
                            <group>
                                <field name="last_sync_message" readonly="1" widget="text"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ANAF e-Factura Action -->
    <record id="action_anaf_efactura" model="ir.actions.act_window">
        <field name="name">Configurare ANAF e-Factura</field>
        <field name="path">configurare-anaf</field>
        <field name="res_model">anaf.efactura</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Audit Log Tree View -->
    <record id="view_audit_log_tree" model="ir.ui.view">
        <field name="name">automotive.audit.log.tree</field>
        <field name="model">automotive.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit Logs" create="false" delete="false">
                <field name="create_date"/>
                <field name="log_type"/>
                <field name="level" optional="show"/>
                <field name="category" optional="show"/>
                <field name="event" optional="show"/>
                <field name="company_id" optional="hide"/>
                <field name="user_id"/>
                <field name="action"/>
                <field name="model_description"/>
                <field name="record_display_name"/>
                <field name="record_id"/>
                <field name="request_path" optional="show"/>
                <field name="description"/>
                <field name="message" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Audit Log Form View -->
    <record id="view_audit_log_form" model="ir.ui.view">
        <field name="name">automotive.audit.log.form</field>
        <field name="model">automotive.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="user_id"/>
                            <field name="log_type"/>
                            <field name="action"/>
                            <field name="model_name"/>
                            <field name="model_description"/>
                            <field name="record_display_name"/>
                            <field name="record_id"/>
                        </group>
                        <group>
                            <field name="create_date"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <group string="Changes">
                        <field name="change_summary" widget="text" readonly="1" nolabel="1"/>
                    </group>
                    <group string="Runtime Event" invisible="log_type != 'runtime'">
                        <group>
                            <field name="level"/>
                            <field name="category"/>
                            <field name="event"/>
                            <field name="source"/>
                            <field name="outcome"/>
                        </group>
                        <group>
                            <field name="db_name"/>
                            <field name="request_method"/>
                            <field name="request_path"/>
                            <field name="related_model"/>
                            <field name="related_res_id"/>
                        </group>
                    </group>
                    <group string="Message" invisible="log_type != 'runtime'">
                        <field name="message" widget="text" readonly="1" nolabel="1"/>
                    </group>
                    <group string="Payload" invisible="log_type != 'runtime'">
                        <field name="payload_json" widget="text" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_audit_log_search" model="ir.ui.view">
        <field name="name">automotive.audit.log.search</field>
        <field name="model">automotive.audit.log</field>
        <field name="arch" type="xml">
            <search string="Audit Logs">
                <field name="create_date"/>
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="log_type"/>
                <field name="action"/>
                <field name="level"/>
                <field name="category"/>
                <field name="event"/>
                <field name="model_name"/>
                <field name="record_display_name"/>
                <field name="request_path"/>
                <field name="message"/>
                <filter string="Business Audit" name="business_audit" domain="[('log_type', '=', 'audit')]"/>
                <filter string="Runtime" name="runtime" domain="[('log_type', '=', 'runtime')]"/>
                <separator/>
                <filter string="Invoice Ingest" name="invoice_ingest"
                        domain="[('model_name', 'in', ['invoice.ingest.job', 'invoice.ingest.job.line'])]"/>
                <filter string="Cereri mecanici" name="mechanic_requests"
                        domain="[('model_name', '=', 'mechanic.portal.request')]"/>
                <filter string="ANAF" name="anaf"
                        domain="[('model_name', '=', 'anaf.efactura')]"/>
                <filter string="Errors" name="runtime_errors" domain="[('log_type', '=', 'runtime'), ('level', 'in', ['error', 'critical'])]"/>
                <filter string="HTTP" name="runtime_http" domain="[('log_type', '=', 'runtime'), ('category', '=', 'http')]"/>
                <filter string="Browser" name="runtime_browser" domain="[('log_type', '=', 'runtime'), ('category', '=', 'browser')]"/>
                <filter string="Async Jobs" name="runtime_async_jobs" domain="[('log_type', '=', 'runtime'), ('category', '=', 'async_job')]"/>
                <separator/>
                <filter string="Creates" name="creates" domain="[('action', '=', 'create')]"/>
                <filter string="Changes" name="changes" domain="[('action', '=', 'write')]"/>
                <filter string="Custom Actions" name="custom_actions" domain="[('action', '=', 'custom')]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_log_type" context="{'group_by': 'log_type'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'model_name'}"/>
                    <filter string="Action" name="group_action" context="{'group_by': 'action'}"/>
                    <filter string="Level" name="group_level" context="{'group_by': 'level'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Event" name="group_event" context="{'group_by': 'event'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Audit Log Action -->
    <record id="action_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Logs</field>
        <field name="path">audit-logs</field>
        <field name="res_model">automotive.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_audit_log_search"/>
    </record>
</odoo>
