<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Menu -->
    <menuitem id="menu_automotive_root"
              name="Piese Auto"
              sequence="10"
              action="action_invoice_ingest_jobs"
              web_icon="automotive_parts,static/description/icon.png"/>

    <record id="menu_invoice_ingest_upload_wizard" model="ir.ui.menu">
        <field name="name">Importă facturi</field>
        <field name="parent_id" ref="menu_automotive_root"/>
        <field name="sequence">20</field>
        <field name="active" eval="False"/>
    </record>

    <menuitem id="menu_invoice_ingest_jobs"
              name="Importuri facturi"
              parent="menu_automotive_root"
              action="action_invoice_ingest_jobs"
              sequence="10"/>

    <record id="action_automotive_order_create" model="ir.actions.act_window">
        <field name="name">Creează comandă</field>
        <field name="path">creeaza-comanda</field>
        <field name="res_model">sale.order</field>
        <field name="view_id" ref="sale.view_order_form"/>
        <field name="view_mode">form,list</field>
        <field name="context">{'default_order_type': 'external'}</field>
    </record>

    <record id="action_automotive_orders_open" model="ir.actions.act_window">
        <field name="name">Istoric comenzi</field>
        <field name="path">istoric-comenzi</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_automotive_orders_done" model="ir.actions.act_window">
        <field name="name">Comenzi finalizate</field>
        <field name="path">comenzi-finalizate</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="domain">[('auto_state', '=', 'delivered')]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_automotive_orders_cancelled" model="ir.actions.act_window">
        <field name="name">Comenzi șterse</field>
        <field name="path">comenzi-sterse</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="domain">['|', ('state', '=', 'cancel'), ('auto_state', '=', 'cancel')]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_automotive_sales_history" model="ir.actions.act_window">
        <field name="name">Istoric vânzări</field>
        <field name="path">istoric-vanzari</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="domain">[('state', 'in', ['sale', 'done'])]</field>
        <field name="context">{'search_default_group_auto_state': 1}</field>
    </record>

    <record id="action_automotive_sell" model="ir.actions.act_window">
        <field name="name">Vinde</field>
        <field name="path">vinde</field>
        <field name="res_model">sale.order</field>
        <field name="view_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="context">{'search_default_my_quotation': 1, 'default_order_type': 'external'}</field>
    </record>

    <menuitem id="menu_automotive_orders"
              name="Comenzi"
              parent="menu_automotive_root"
              sequence="20"/>

    <record id="menu_automotive_order_create" model="ir.ui.menu">
        <field name="name">Creează comandă</field>
        <field name="parent_id" ref="menu_automotive_orders"/>
        <field name="sequence">10</field>
        <field name="active" eval="False"/>
    </record>

    <record id="menu_automotive_orders_done" model="ir.ui.menu">
        <field name="name">Comenzi finalizate</field>
        <field name="parent_id" ref="menu_automotive_orders"/>
        <field name="sequence">20</field>
        <field name="active" eval="False"/>
    </record>

    <menuitem id="menu_automotive_orders_open"
              name="Istoric comenzi"
              parent="menu_automotive_orders"
              action="action_automotive_orders_open"
              sequence="10"/>

    <record id="menu_automotive_orders_cancelled" model="ir.ui.menu">
        <field name="name">Comenzi șterse</field>
        <field name="parent_id" ref="menu_automotive_orders"/>
        <field name="sequence">40</field>
        <field name="active" eval="False"/>
    </record>

    <menuitem id="menu_automotive_sales"
              name="Vânzări"
              parent="menu_automotive_root"
              sequence="30"/>

    <menuitem id="menu_automotive_sales_history"
              name="Istoric vânzări"
              parent="menu_automotive_sales"
              action="action_automotive_sales_history"
              sequence="10"/>

    <menuitem id="menu_automotive_sell"
              name="Vinde"
              parent="menu_automotive_sales"
              action="action_automotive_sell"
              sequence="20"/>

    <menuitem id="menu_stock_workspace"
              name="Stocuri"
              parent="menu_automotive_root"
              sequence="40"/>

    <menuitem id="menu_stock_workspace_overview"
              name="Panou stoc"
              parent="menu_stock_workspace"
              action="action_automotive_stock_workspace"
              sequence="10"/>

    <menuitem id="menu_stock_workspace_receptions"
              name="Recepții / NIR"
              parent="menu_stock_workspace"
              action="stock.action_picking_tree_incoming"
              sequence="20"/>

    <menuitem id="menu_stock_workspace_deliveries"
              name="Livrări"
              parent="menu_stock_workspace"
              action="stock.action_picking_tree_outgoing"
              sequence="30"/>

    <menuitem id="menu_stock_workspace_internal"
              name="Transferuri interne"
              parent="menu_stock_workspace"
              action="stock.action_picking_tree_internal"
              sequence="40"/>

    <menuitem id="menu_stock_workspace_inventory"
              name="Ajustări inventar"
              parent="menu_stock_workspace"
              action="stock.action_view_inventory_tree"
              sequence="50"/>

    <menuitem id="menu_stock_workspace_replenishment"
              name="Reaprovizionare"
              parent="menu_stock_workspace"
              action="stock.action_orderpoint"
              sequence="60"/>

    <menuitem id="menu_commercial_documents"
              name="Documente comerciale"
              parent="menu_automotive_root"
              sequence="50"/>

    <menuitem id="menu_commercial_documents_vendor_bills"
              name="Facturi furnizor"
              parent="menu_commercial_documents"
              action="account.action_move_in_invoice_type"
              sequence="10"/>

    <menuitem id="menu_commercial_documents_customer_invoices"
              name="Facturi clienți"
              parent="menu_commercial_documents"
              action="account.action_move_out_invoice_type"
              sequence="20"/>

    <menuitem id="menu_configurare"
              name="Configurare"
              parent="menu_automotive_root"
              sequence="100"/>

    <menuitem id="menu_tecdoc_config"
              name="Configurare TecDoc"
              parent="menu_configurare"
              action="action_tecdoc_api"
              sequence="10"/>

    <menuitem id="menu_tecdoc_sync"
              name="Sincronizare produse"
              parent="menu_configurare"
              action="action_tecdoc_sync_wizard"
              sequence="20"/>

    <menuitem id="menu_tecdoc_products"
              name="Produse"
              parent="menu_configurare"
              action="action_tecdoc_fast_products"
              sequence="30"/>

    <menuitem id="menu_anaf_config"
              name="Configurare ANAF"
              parent="menu_configurare"
              action="action_anaf_efactura"
              sequence="40"/>

    <!-- Audit Log Menu -->
    <record id="menu_audit_log" model="ir.ui.menu">
        <field name="name">Audit Logs</field>
        <field name="parent_id" ref="menu_automotive_root"/>
        <field name="sequence">90</field>
        <field name="action" eval="False"/>
    </record>

    <menuitem id="menu_business_audit_log"
              name="Audit Logs"
              parent="menu_audit_log"
              action="action_audit_log"
              sequence="10"/>

    <menuitem id="menu_runtime_log"
              name="Runtime Logs"
              parent="menu_audit_log"
              action="action_runtime_log"
              sequence="20"/>

    <record id="menu_tecdoc" model="ir.ui.menu">
        <field name="name">TecDoc</field>
        <field name="active" eval="False"/>
    </record>

    <record id="menu_anaf" model="ir.ui.menu">
        <field name="name">ANAF</field>
        <field name="active" eval="False"/>
    </record>

    <record id="menu_tecdoc_fast_import" model="ir.ui.menu">
        <field name="name">TecDoc Fast Import</field>
        <field name="active" eval="False"/>
    </record>

</odoo>
