<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_automotive_stock_workspace_search" model="ir.ui.view">
        <field name="name">automotive.stock.workspace.search</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <search string="Automotive Stock Workspace">
                <field name="product_id"/>
                <field name="product_tmpl_id"/>
                <field name="location_id"/>
                <field name="warehouse_id"/>
                <field name="lot_id"/>
                <field name="package_id"/>
                <field name="owner_id"/>
                <field name="company_id"/>
                <field name="inventory_date"/>
                <field name="last_count_date"/>
                <filter string="Internal Locations" name="internal_loc" domain="[('location_id.usage', '=', 'internal')]"/>
                <filter string="Transit Locations" name="transit_loc" domain="[('location_id.usage', '=', 'transit')]"/>
                <filter string="Available" name="available" domain="[('quantity', '&gt;', 0.0), ('reserved_quantity', '=', 0.0)]"/>
                <filter string="Reserved" name="reserved" domain="[('reserved_quantity', '&gt;', 0.0)]"/>
                <filter string="Zero / Negative" name="zero_negative" domain="[('quantity', '&lt;=', 0.0)]"/>
                <filter string="With Lot/Serial" name="with_lot" domain="[('lot_id', '!=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Location" name="group_location" context="{'group_by': 'location_id'}"/>
                    <filter string="Warehouse" name="group_warehouse" context="{'group_by': 'warehouse_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Lot / Serial" name="group_lot" context="{'group_by': 'lot_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_automotive_stock_workspace_tree" model="ir.ui.view">
        <field name="name">automotive.stock.workspace.tree</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <list string="Automotive Stock Workspace"
                  create="0" edit="0" delete="0"
                  default_order="product_id, location_id"
                  decoration-success="quantity &gt; 0 and reserved_quantity == 0"
                  decoration-warning="reserved_quantity &gt; 0"
                  decoration-danger="quantity &lt;= 0">
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="warehouse_id" optional="show"/>
                <field name="quantity"/>
                <field name="reserved_quantity"/>
                <field name="available_quantity"/>
                <field name="lot_id" optional="show"/>
                <field name="package_id" optional="hide"/>
                <field name="owner_id" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <button name="action_view_stock_moves" string="History" type="object" class="btn-link" icon="fa-history"/>
                <button name="action_view_orderpoints" string="Replenishment" type="object" class="btn-link" icon="fa-refresh"/>
            </list>
        </field>
    </record>

    <record id="view_automotive_stock_workspace_form" model="ir.ui.view">
        <field name="name">automotive.stock.workspace.form</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_form_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_stock_moves" type="object" class="oe_stat_button" icon="fa-history">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Lifecycle</span>
                            <span class="o_stat_text">History</span>
                        </div>
                    </button>
                    <button name="action_view_orderpoints" type="object" class="oe_stat_button" icon="fa-refresh">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Replenishment</span>
                            <span class="o_stat_text">Rule</span>
                        </div>
                    </button>
                </div>
                <group string="Automotive Lifecycle">
                    <group>
                        <field name="product_id" readonly="1"/>
                        <field name="location_id" readonly="1"/>
                        <field name="warehouse_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="quantity" readonly="1"/>
                        <field name="reserved_quantity" readonly="1"/>
                        <field name="available_quantity" readonly="1"/>
                    </group>
                    <group>
                        <field name="inventory_date" readonly="1"/>
                        <field name="last_count_date" readonly="1"/>
                        <field name="lot_id" readonly="1"/>
                        <field name="package_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="owner_id" readonly="1"/>
                        <field name="company_id" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_automotive_stock_workspace" model="ir.actions.act_window">
        <field name="name">Stock Workspace</field>
        <field name="path">automotive-stock-workspace</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="view_id" ref="view_automotive_stock_workspace_tree"/>
        <field name="search_view_id" ref="view_automotive_stock_workspace_search"/>
        <field name="context">{'search_default_internal_loc': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                View stock by product, location, warehouse, and reservation state.
            </p>
            <p>
                Use the row actions to inspect lifecycle history or the linked replenishment rule.
            </p>
        </field>
    </record>

    <!-- Extended Product Template Form View (this is what Inventory → Products opens) -->
    <record id="view_product_template_form_automotive" model="ir.ui.view">
        <field name="name">product.template.form.automotive</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_open_label_layout']" position="replace">
                <button name="action_generate_label"
                        string="Genereaza eticheta"
                        type="object"
                        invisible="type == 'service'"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="%(action_automotive_stock_workspace)d"
                        type="action"
                        string="Stock Workspace"
                        class="btn-secondary"
                        context="{'search_default_product_tmpl_id': id, 'search_default_internal_loc': 1}"/>
            </xpath>

            <!-- Odoo 18 base view doesn't show default_code by default on product.template; inject it. -->
            <xpath expr="//page[@name='general_information']//group[@name='group_general']" position="inside">
                <field name="active"/>
                <field name="default_code" string="Article No"/>
                <field name="barcode"/>
                <field name="barcode_internal"/>
                <field name="supplier_code"/>
                <field name="main_supplier_id"/>
            </xpath>

            <notebook position="inside">
                <page string="Product Data" name="tecdoc">
                    <group>
                        <group string="Supplier">
                            <field name="tecdoc_supplier_id" string="Supplier ID"/>
                            <field name="tecdoc_supplier_name" string="Supplier"/>
                        </group>
                    </group>

                    <group string="Identifiers">
                        <field name="default_code" string="Cod Intern"/>
                        <field name="barcode" string="EAN"/>
                        <field name="barcode_internal"/>
                        <field name="supplier_code"/>
                        <field name="tecdoc_ean" string="EAN TecDoc" readonly="1"/>
                        <field name="tecdoc_oem_numbers" string="OEM Numbers" widget="text"/>
                    </group>

                    <group string="Specifications">
                        <field name="tecdoc_specifications" string="Specifications (legacy)" widget="text" invisible="1"/>
                    </group>

                    <group string="Vehicle Compatibility">
                        <field name="tecdoc_compatibility" string="Compatibility (legacy)" widget="text" invisible="1"/>
                    </group>

                    <group string="Media">
                        <field name="tecdoc_image_url" string="Image URL (raw)"/>
                        <field name="tecdoc_media_type" string="Media Type" readonly="1"/>
                        <field name="tecdoc_media_filename" string="Media Filename" readonly="1"/>
                    </group>

                    <group>
                        <group string="Stock">
                            <field name="stock_available" readonly="1"/>
                            <field name="stock_reserved" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <button name="action_sync_from_tecdoc" string="Sync from TecDoc"
                                type="object" class="btn-primary"
                                invisible="tecdoc_fast_managed or (not tecdoc_article_no and not tecdoc_id)"/>
                        <button name="action_view_compatible_vehicles" string="Compatible Vehicles"
                                type="object" class="btn-secondary"
                                invisible="not tecdoc_article_no"/>
                        <button name="action_generate_label" string="Genereaza eticheta"
                                type="object" class="btn-secondary"/>
                    </group>
                </page>

                <page string="Stock Alerts" name="stock_alerts">
                    <field name="product_variant_count" invisible="1"/>
                    <group invisible="product_variant_count != 1">
                        <group string="Alert settings">
                            <field name="stock_alert_enabled"/>
                            <field name="stock_alert_state" readonly="1"/>
                            <field name="stock_alert_orderpoint_id" readonly="1"/>
                        </group>
                        <group string="Thresholds">
                            <field name="stock_alert_min_qty"/>
                            <field name="stock_alert_target_qty"/>
                            <field name="stock_alert_qty_to_order" readonly="1"/>
                        </group>
                        <group string="Default replenishment location">
                            <field name="stock_alert_warehouse_id" readonly="1"/>
                            <field name="stock_alert_location_id" readonly="1"/>
                        </group>
                        <group string="Actions">
                            <button name="action_view_stock_alert_orderpoint"
                                    string="Open linked replenishment"
                                    type="object"
                                    class="btn-primary"/>
                            <button name="action_sync_stock_alert_orderpoint"
                                    string="Resync alert"
                                    type="object"
                                    class="btn-secondary"/>
                        </group>
                    </group>
                    <group invisible="product_variant_count == 1">
                        <div class="text-muted">
                            Stock alerts are managed per variant. Open a single-variant product or the variant form to configure the refill rule.
                        </div>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Product Tree View -->
    <record id="view_product_tree_automotive" model="ir.ui.view">
        <field name="name">product.product.tree.automotive</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_open_label_layout']" position="replace">
                <button name="action_generate_label" string="Genereaza eticheta" type="object"/>
            </xpath>

            <field name="lst_price" position="after">
                <field name="active" optional="show"/>
                <field name="default_code"/>
                <field name="barcode"/>
                <field name="barcode_internal"/>
                <field name="supplier_code"/>
                <field name="tecdoc_article_no"/>
                <field name="tecdoc_id"/>
                <field name="stock_available"/>
                <field name="stock_reserved"/>
                <field name="stock_alert_enabled"/>
                <field name="stock_alert_state"/>
                <field name="stock_alert_min_qty"/>
                <field name="stock_alert_target_qty"/>
                <field name="stock_alert_qty_to_order"/>
                <field name="is_automotive_part"/>
            </field>
        </field>
    </record>
</odoo>
