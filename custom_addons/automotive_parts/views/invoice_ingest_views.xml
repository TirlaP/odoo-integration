<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_ingest_job_tree" model="ir.ui.view">
        <field name="name">invoice.ingest.job.tree</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <list string="Invoice Ingest Jobs">
                <field name="create_date"/>
                <field name="name"/>
                <field name="source"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="invoice_number"/>
                <field name="invoice_date"/>
                <field name="amount_total"/>
                <field name="picking_id"/>
                <field name="account_move_id"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_ingest_job_form" model="ir.ui.view">
        <field name="name">invoice.ingest.job.form</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <form string="Invoice Ingest Job">
                <header>
                    <button name="action_open_upload_wizard" type="object" class="btn-primary"
                            string="Import AI (PDF)"/>
                    <button name="action_open_react_view" type="object" class="btn-secondary"
                            string="Modern React View"/>
                    <button name="action_run" type="object" class="btn-primary" string="Run"
                            invisible="state not in ('pending','failed','needs_review')"/>
                    <button name="action_extract_with_openai" type="object" class="btn-primary"
                            string="Extract with OpenAI" invisible="attachment_id == False"/>
                    <button name="action_create_draft_vendor_bill" type="object" class="btn-secondary"
                            string="Create Draft Vendor Bill" invisible="account_move_id != False"/>
                    <button name="action_sync_receipt_stock" type="object" class="btn-secondary"
                            string="Sync Receipt + Stock" invisible="not line_ids"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,running,needs_review,done,failed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="source"/>
                            <field name="picking_id"/>
                            <field name="attachment_id"/>
                            <field name="ai_model"/>
                            <field name="ai_confidence" readonly="1"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="invoice_number"/>
                            <field name="invoice_date"/>
                            <field name="vat_rate"/>
                            <field name="amount_total"/>
                            <field name="account_move_id"/>
                        </group>
                    </group>
                    <group string="Extracted Lines" class="o_invoice_ingest_lines_wrap" invisible="not line_ids">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom" class="o_invoice_ingest_lines_table">
                                <field name="sequence" widget="handle"/>
                                <field name="product_code"/>
                                <field name="supplier_brand"/>
                                <field name="supplier_brand_id" optional="hide"/>
                                <field name="product_description"/>
                                <field name="quantity"/>
                                <field name="unit_price"/>
                                <field name="unit_price_incl_vat" readonly="1"/>
                                <field name="matched_ean" readonly="1"/>
                                <field name="matched_internal_code" readonly="1"/>
                                <field name="product_id"/>
                                <field name="match_status" readonly="1"/>
                                <button name="action_try_match" type="object" icon="fa-search" string="" title="Try match"/>
                                <button name="action_clear_match" type="object" icon="fa-eraser" string="" title="Clear match"/>
                            </list>
                        </field>
                    </group>
                    <group string="Diagnostics" invisible="payload_json == False and error == False">
                        <field name="external_id"/>
                        <field name="error" widget="text"/>
                        <field name="payload_json" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_ingest_jobs" model="ir.actions.act_window">
        <field name="name">Invoice Ingest Jobs</field>
        <field name="path">automotive-invoice-ingest</field>
        <field name="res_model">invoice.ingest.job</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_invoice_ingest_upload_wizard_form" model="ir.ui.view">
        <field name="name">invoice.ingest.upload.wizard.form</field>
        <field name="model">invoice.ingest.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Import AI (PDF)">
                <sheet>
                    <group>
                        <field name="pdf_file" filename="pdf_filename" widget="pdf_drop_binary"
                               options="{'accepted_file_extensions': '.pdf'}"/>
                        <field name="pdf_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="supplier_id"/>
                        <field name="ai_model"/>
                        <field name="auto_extract"/>
                    </group>
                    <div class="text-muted">
                        Drop one PDF and click Import. AI extraction can run automatically.
                    </div>
                </sheet>
                <footer>
                    <button name="action_import_pdf" type="object" string="Import PDF" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_ingest_upload_wizard" model="ir.actions.act_window">
        <field name="name">Import AI (PDF)</field>
        <field name="res_model">invoice.ingest.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
