<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_invoice_ingest_upload_wizard" model="ir.actions.act_window">
        <field name="name">Importă AI</field>
        <field name="path">import-ai-facturi</field>
        <field name="res_model">invoice.ingest.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_invoice_ingest_job_tree" model="ir.ui.view">
        <field name="name">invoice.ingest.job.tree</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <list string="Importuri facturi" default_order="create_date desc" create="0">
                <header>
                    <button name="%(action_invoice_ingest_upload_wizard)d"
                            type="action"
                            string="Importă AI"
                            class="btn-primary"
                            display="always"/>
                </header>
                <field name="create_date"/>
                <field name="name"/>
                <field name="source"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-warning="state == 'running'"
                       decoration-primary="state == 'needs_review'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'failed'"/>
                <field name="partner_id"/>
                <field name="invoice_date"/>
                <field name="amount_total"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_ingest_job_search" model="ir.ui.view">
        <field name="name">invoice.ingest.job.search</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <search string="Importuri facturi">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="invoice_number"/>
                <field name="source"/>
                <field name="state"/>
                <filter string="Queued" name="queued" domain="[('state', '=', 'pending')]"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <filter string="Needs Review" name="needs_review" domain="[('state', '=', 'needs_review')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <filter string="Lines: Prefix Alias" name="line_prefix_alias" domain="[('line_ids.match_review_bucket', '=', 'possible_prefix_alias')]"/>
                <filter string="Lines: Bad Parse" name="line_bad_parse" domain="[('line_ids.match_review_bucket', '=', 'bad_parse')]"/>
                <filter string="Lines: No Match" name="line_no_match" domain="[('line_ids.match_review_bucket', '=', 'no_match')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Source" name="group_source" context="{'group_by': 'source'}"/>
                    <filter string="Supplier" name="group_partner" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_invoice_ingest_job_line_review_list" model="ir.ui.view">
        <field name="name">invoice.ingest.job.line.review.list</field>
        <field name="model">invoice.ingest.job.line</field>
        <field name="arch" type="xml">
            <list string="Invoice Lines Review" default_order="write_date desc, job_id desc, sequence">
                <field name="job_id"/>
                <field name="sequence"/>
                <field name="product_code_raw"/>
                <field name="product_code"/>
                <field name="supplier_brand"/>
                <field name="product_description"/>
                <field name="product_id"/>
                <field name="match_status"/>
                <field name="match_review_bucket"/>
                <field name="match_method"/>
                <field name="match_confidence"/>
                <button name="action_try_match" type="object" icon="fa-search" string="" title="Try match"/>
                <button name="action_open_tecdoc_match" type="object" icon="fa-database" string="" title="Match TecDoc" invisible="product_id"/>
                <button name="action_learn_mapping" type="object" icon="fa-link" string="" title="Save learned mapping" invisible="not product_id"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_ingest_job_line_review_search" model="ir.ui.view">
        <field name="name">invoice.ingest.job.line.review.search</field>
        <field name="model">invoice.ingest.job.line</field>
        <field name="arch" type="xml">
            <search string="Invoice Lines Review">
                <field name="job_id"/>
                <field name="product_code_raw"/>
                <field name="product_code"/>
                <field name="supplier_brand"/>
                <field name="product_description"/>
                <field name="product_id"/>
                <field name="match_review_bucket"/>
                <filter string="Prefix Alias" name="possible_prefix_alias" domain="[('match_review_bucket', '=', 'possible_prefix_alias')]"/>
                <filter string="Bad Parse" name="bad_parse" domain="[('match_review_bucket', '=', 'bad_parse')]"/>
                <filter string="Manual Review" name="manual_review" domain="[('match_review_bucket', '=', 'manual_review')]"/>
                <filter string="No Match" name="no_match" domain="[('match_review_bucket', '=', 'no_match')]"/>
                <filter string="Learned" name="learned" domain="[('match_review_bucket', '=', 'learned')]"/>
                <group expand="0" string="Group By">
                    <filter string="Bucket" name="group_bucket" context="{'group_by': 'match_review_bucket'}"/>
                    <filter string="Job" name="group_job" context="{'group_by': 'job_id'}"/>
                    <filter string="Brand" name="group_brand" context="{'group_by': 'supplier_brand'}"/>
                    <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_invoice_ingest_job_form" model="ir.ui.view">
        <field name="name">invoice.ingest.job.form</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <form string="Invoice Ingest Job" create="0">
                <header>
                    <button name="action_open_upload_wizard" type="object" class="btn-primary"
                            string="Importă AI"/>
                    <button name="action_reprocess" type="object" class="btn-secondary"
                            string="Reprocesează"
                            invisible="source != 'ocr' or not attachment_id or state == 'running' or receipt_sync_state == 'synced'"/>
                    <button name="action_sync_receipt_stock" type="object" class="btn-secondary"
                            string="Sync Receipt + Bill" invisible="not line_ids or receipt_sync_state == 'synced'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,running,needs_review,done,failed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_upload_wizard" type="object" class="oe_stat_button" icon="fa-upload">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Import</span>
                                <span class="o_stat_text">Document nou</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="source"/>
                            <field name="batch_uid" invisible="1"/>
                            <field name="finished_at" invisible="1"/>
                            <field name="duplicate_of_job_id" invisible="1"/>
                            <field name="duplicate_warning_message" invisible="1"/>
                            <field name="active_async_job_id" invisible="1"/>
                            <field name="document_type"/>
                            <field name="picking_id" string="Stock Receipt (Optional)"/>
                            <field name="receipt_sync_state" readonly="1"/>
                            <field name="attachment_id"/>
                            <field name="async_progress_message" readonly="1" invisible="not active_async_job_id"/>
                            <field name="async_progress_percent" widget="progressbar" readonly="1" invisible="not active_async_job_id"/>
                            <field name="ai_confidence" readonly="1"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="invoice_number"/>
                            <field name="invoice_date"/>
                            <field name="vat_rate"/>
                            <field name="amount_total"/>
                            <field name="account_move_id" string="Linked Vendor Bill"/>
                        </group>
                    </group>
                    <group string="Extracted Lines" class="o_invoice_ingest_lines_wrap">
                        <field name="line_extraction_message" nolabel="1" readonly="1" invisible="line_ids"/>
                        <field name="line_ids" nolabel="1" invisible="not line_ids">
                            <list editable="bottom" class="o_invoice_ingest_lines_table">
                                <field name="sequence" widget="handle"/>
                                <field name="label_display_name" string="Denumire" readonly="1"/>
                                <field name="label_barcode_value" string="Cod de bare"/>
                                <field name="product_code" string="Cod produs"/>
                                <field name="matched_internal_code" string="Cod intern"/>
                                <field name="supplier_brand"/>
                                <field name="supplier_brand_id" optional="hide"/>
                                <field name="product_description" optional="hide"/>
                                <field name="quantity"/>
                                <field name="unit_price"/>
                                <field name="unit_price_incl_vat" readonly="1"/>
                                <field name="product_id"/>
                                <field name="match_status" readonly="1"/>
                                <field name="match_review_bucket" readonly="1" optional="show"/>
                                <button name="action_try_match" type="object" icon="fa-search" string="" title="Try match"/>
                                <button name="action_open_tecdoc_match" type="object" icon="fa-database" string="" title="Match TecDoc" invisible="product_id"/>
                                <button name="action_learn_mapping" type="object" icon="fa-link" string="" title="Save learned mapping" invisible="not product_id"/>
                                <button name="action_clear_match" type="object" icon="fa-eraser" string="" title="Clear match"/>
                                <button name="action_generate_label" type="object" string="Genereaza eticheta" title="Genereaza eticheta"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_ingest_jobs" model="ir.actions.act_window">
        <field name="name">Importuri facturi</field>
        <field name="path">importuri-facturi</field>
        <field name="res_model">invoice.ingest.job</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_invoice_ingest_job_search"/>
    </record>

    <record id="action_invoice_ingest_line_review" model="ir.actions.act_window">
        <field name="name">Linii de verificat</field>
        <field name="path">linii-facturi-review</field>
        <field name="res_model">invoice.ingest.job.line</field>
        <field name="view_mode">list</field>
        <field name="domain">[('match_review_bucket', 'in', ['possible_prefix_alias', 'bad_parse', 'manual_review', 'no_match'])]</field>
        <field name="context">{'search_default_group_bucket': 1}</field>
        <field name="search_view_id" ref="view_invoice_ingest_job_line_review_search"/>
    </record>

    <record id="view_invoice_ingest_upload_wizard_form" model="ir.ui.view">
        <field name="name">invoice.ingest.upload.wizard.form</field>
        <field name="model">invoice.ingest.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Importă AI (PDF/Imagine)">
                <sheet>
                    <group>
                        <field name="upload_attachment_ids" widget="many2many_binary"
                               class="o_invoice_ingest_upload_attachments"
                               options="{'accepted_file_extensions': '.pdf,.png,.jpg,.jpeg,.webp,.tif,.tiff'}"/>
                    </group>
                    <group>
                        <field name="supplier_id"/>
                    </group>
                    <div class="text-muted">
                        Încarcă unul sau mai multe documente și apasă Importă.
                        Fiecare document va fi analizat automat, iar rezultatele vor apărea în lista de importuri facturi.
                    </div>
                </sheet>
                <footer>
                    <button name="action_import_document" type="object" string="Importă documente" class="btn-primary"/>
                    <button string="Anulează" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
