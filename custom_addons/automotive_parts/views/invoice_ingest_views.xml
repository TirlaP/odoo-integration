<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_ingest_job_tree" model="ir.ui.view">
        <field name="name">invoice.ingest.job.tree</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <list string="Importuri facturi">
                <field name="create_date"/>
                <field name="batch_name" optional="show"/>
                <field name="batch_index" optional="show"/>
                <field name="batch_total" optional="show"/>
                <field name="name"/>
                <field name="source"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="invoice_number"/>
                <field name="invoice_date"/>
                <field name="amount_total"/>
                <field name="picking_id"/>
                <field name="account_move_id"/>
                <field name="queued_at" optional="show"/>
                <field name="started_at" optional="show"/>
                <field name="finished_at" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_ingest_job_search" model="ir.ui.view">
        <field name="name">invoice.ingest.job.search</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <search string="Importuri facturi">
                <field name="name"/>
                <field name="batch_name"/>
                <field name="partner_id"/>
                <field name="invoice_number"/>
                <field name="source"/>
                <field name="state"/>
                <filter string="Queued" name="queued" domain="[('state', '=', 'pending')]"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <filter string="Needs Review" name="needs_review" domain="[('state', '=', 'needs_review')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Batch" name="group_batch_uid" context="{'group_by': 'batch_name'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Source" name="group_source" context="{'group_by': 'source'}"/>
                    <filter string="Supplier" name="group_partner" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_invoice_ingest_job_form" model="ir.ui.view">
        <field name="name">invoice.ingest.job.form</field>
        <field name="model">invoice.ingest.job</field>
        <field name="arch" type="xml">
            <form string="Invoice Ingest Job">
                <header>
                    <button name="action_open_upload_wizard" type="object" class="btn-primary"
                            string="Import AI facturi"/>
                    <button name="action_run" type="object" class="btn-primary" string="Queue Processing"
                            invisible="state not in ('pending','failed')"/>
                    <button name="action_create_draft_vendor_bill" type="object" class="btn-secondary"
                            string="Create Draft Vendor Bill" invisible="account_move_id != False"/>
                    <button name="action_sync_receipt_stock" type="object" class="btn-secondary"
                            string="Sync Receipt + Stock" invisible="not line_ids or receipt_sync_state == 'synced'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,running,needs_review,done,failed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="action" name="%(action_invoice_ingest_upload_wizard)d" class="oe_stat_button" icon="fa-upload">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Import</span>
                                <span class="o_stat_text">Document nou</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="source"/>
                            <field name="batch_name"/>
                            <field name="batch_uid" invisible="1"/>
                            <field name="batch_index"/>
                            <field name="batch_total"/>
                            <field name="document_type"/>
                            <field name="picking_id" string="Stock Receipt (Optional)"/>
                            <field name="receipt_sync_state" readonly="1"/>
                            <field name="attachment_id"/>
                            <field name="ai_confidence" readonly="1"/>
                            <field name="queued_at" readonly="1"/>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="invoice_number"/>
                            <field name="invoice_date"/>
                            <field name="vat_rate"/>
                            <field name="amount_total"/>
                            <field name="account_move_id" string="Linked Vendor Bill"/>
                        </group>
                    </group>
                    <group string="Document Routing">
                        <group>
                            <field name="attachment_id" readonly="1"/>
                            <field name="picking_id" string="Stock Receipt" readonly="1"/>
                            <field name="account_move_id" string="Vendor Bill" readonly="1"/>
                        </group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="invoice_number" readonly="1"/>
                            <field name="invoice_date" readonly="1"/>
                            <field name="receipt_sync_state" readonly="1"/>
                        </group>
                    </group>
                    <group string="Extracted Lines" class="o_invoice_ingest_lines_wrap" invisible="not line_ids">
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom" class="o_invoice_ingest_lines_table">
                                <field name="sequence" widget="handle"/>
                                <field name="label_display_name" string="Denumire" readonly="1"/>
                                <field name="label_barcode_value" string="Cod de bare" readonly="1"/>
                                <field name="product_code" string="Cod produs"/>
                                <field name="matched_internal_code" string="Cod intern" readonly="1"/>
                                <field name="supplier_brand"/>
                                <field name="supplier_brand_id" optional="hide"/>
                                <field name="product_description" optional="hide"/>
                                <field name="quantity"/>
                                <field name="unit_price"/>
                                <field name="unit_price_incl_vat" readonly="1"/>
                                <field name="product_id"/>
                                <field name="match_status" readonly="1"/>
                                <button name="action_try_match" type="object" icon="fa-search" string="" title="Try match"/>
                                <button name="action_clear_match" type="object" icon="fa-eraser" string="" title="Clear match"/>
                                <button name="action_generate_label" type="object" string="Genereaza eticheta" title="Genereaza eticheta"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_invoice_ingest_jobs" model="ir.actions.act_window">
        <field name="name">Importuri facturi</field>
        <field name="path">importuri-facturi</field>
        <field name="res_model">invoice.ingest.job</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_invoice_ingest_job_search"/>
    </record>

    <record id="view_invoice_ingest_upload_wizard_form" model="ir.ui.view">
        <field name="name">invoice.ingest.upload.wizard.form</field>
        <field name="model">invoice.ingest.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Import AI facturi (PDF/Imagine)">
                <sheet>
                    <group>
                        <field name="upload_attachment_ids" widget="many2many_binary"
                               options="{'accepted_file_extensions': '.pdf,.png,.jpg,.jpeg,.webp,.tif,.tiff'}"/>
                        <field name="pdf_file" filename="pdf_filename" widget="binary"
                               options="{'accepted_file_extensions': '.pdf,.png,.jpg,.jpeg,.webp,.tif,.tiff'}"
                               invisible="upload_attachment_ids"/>
                        <field name="pdf_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="supplier_id"/>
                    </group>
                    <div class="text-muted">
                        Încarcă unul sau mai multe PDF-uri sau imagini și apasă Importă. Fiecare fișier devine un job pus la coadă.
                        Extracția textului din PDF rulează prima; paginile scanate și imaginile folosesc OCR dacă serverul are Tesseract instalat.
                    </div>
                </sheet>
                <footer>
                    <button name="action_import_document" type="object" string="Importă documente" class="btn-primary"/>
                    <button string="Anulează" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_ingest_upload_wizard" model="ir.actions.act_window">
        <field name="name">Import AI facturi</field>
        <field name="path">import-ai-facturi</field>
        <field name="res_model">invoice.ingest.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
