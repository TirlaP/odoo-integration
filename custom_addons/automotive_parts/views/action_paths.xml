<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Odoo's /odoo/<path> router resolves plain segments by ir.actions.actions.path.
      We want hierarchical URLs like:
        /odoo/automotive-parts/products
        /odoo/automotive-parts/cache
        /odoo/automotive-parts/vehicles

      "products" is used by Sale by default, so we move it away to avoid collisions.
    -->

    <record id="sale.product_template_action" model="ir.actions.act_window">
        <field name="path">sale-products</field>
    </record>

    <record id="action_automotive_stock_workspace" model="ir.actions.act_window">
        <field name="path">automotive-stock-workspace</field>
    </record>

    <record id="stock.action_view_quants" model="ir.actions.server">
        <field name="path">automotive-stock-quants</field>
    </record>

    <record id="stock.action_view_inventory_tree" model="ir.actions.server">
        <field name="path">automotive-stock-adjustments</field>
    </record>

    <record id="stock.action_picking_tree_incoming" model="ir.actions.act_window">
        <field name="path">automotive-receptions</field>
    </record>

    <record id="stock.action_picking_tree_outgoing" model="ir.actions.act_window">
        <field name="path">automotive-deliveries</field>
    </record>

    <record id="stock.action_picking_tree_internal" model="ir.actions.act_window">
        <field name="path">automotive-transfers</field>
    </record>

    <record id="stock.action_orderpoint" model="ir.actions.act_window">
        <field name="path">automotive-replenishment</field>
    </record>

    <record id="action_automotive_payment_allocations" model="ir.actions.act_window">
        <field name="path">automotive-payment-allocations</field>
    </record>

    <record id="action_mechanic_portal_requests" model="ir.actions.act_window">
        <field name="path">automotive-mechanic-requests</field>
    </record>

    <record id="action_commercial_document_archive" model="ir.actions.act_window">
        <field name="path">automotive-commercial-documents</field>
    </record>

    <record id="action_invoice_ingest_jobs" model="ir.actions.act_window">
        <field name="path">automotive-invoice-ingest</field>
    </record>

    <record id="action_invoice_ingest_upload_wizard" model="ir.actions.act_window">
        <field name="path">automotive-invoice-import</field>
    </record>

    <record id="action_anaf_efactura" model="ir.actions.act_window">
        <field name="path">automotive-anaf-config</field>
    </record>

    <record id="action_audit_log" model="ir.actions.act_window">
        <field name="path">automotive-audit-log</field>
    </record>

    <record id="action_automotive_parts_root" model="ir.actions.act_window">
        <field name="name">Automotive Parts</field>
        <field name="path">automotive-parts</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="automotive_parts.view_product_template_search_tecdoc_fast"/>
        <field name="domain">[('tecdoc_variant_ids','!=',False)]</field>
        <field name="context">{}</field>
    </record>
</odoo>
