<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_automotive_label" model="report.paperformat">
            <field name="name">Automotive Label Large</field>
            <field name="default" eval="False"/>
            <field name="format">custom</field>
            <field name="page_width">280</field>
            <field name="page_height">423</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">96</field>
            <field name="disable_shrinking" eval="True"/>
        </record>

        <record id="action_report_automotive_label" model="ir.actions.report">
            <field name="name">Automotive Label</field>
            <field name="model">product.template</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">automotive_parts.report_product_label</field>
            <field name="report_file">automotive_parts.report_product_label</field>
            <field name="paperformat_id" ref="automotive_parts.paperformat_automotive_label"/>
            <field name="binding_model_id" ref="product.model_product_template"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Automotive Label'</field>
        </record>

        <record id="product.report_product_template_label_2x7" model="ir.actions.report">
            <field name="name">Automotive Label</field>
            <field name="report_name">automotive_parts.report_product_label</field>
            <field name="report_file">automotive_parts.report_product_label</field>
            <field name="paperformat_id" ref="automotive_parts.paperformat_automotive_label"/>
            <field name="print_report_name">'Automotive Label'</field>
        </record>

        <record id="product.report_product_template_label_4x7" model="ir.actions.report">
            <field name="name">Automotive Label</field>
            <field name="report_name">automotive_parts.report_product_label</field>
            <field name="report_file">automotive_parts.report_product_label</field>
            <field name="paperformat_id" ref="automotive_parts.paperformat_automotive_label"/>
            <field name="print_report_name">'Automotive Label'</field>
        </record>

        <record id="product.report_product_template_label_4x12" model="ir.actions.report">
            <field name="name">Automotive Label</field>
            <field name="report_name">automotive_parts.report_product_label</field>
            <field name="report_file">automotive_parts.report_product_label</field>
            <field name="paperformat_id" ref="automotive_parts.paperformat_automotive_label"/>
            <field name="print_report_name">'Automotive Label'</field>
        </record>

        <record id="product.report_product_template_label_4x12_noprice" model="ir.actions.report">
            <field name="name">Automotive Label</field>
            <field name="report_name">automotive_parts.report_product_label</field>
            <field name="report_file">automotive_parts.report_product_label</field>
            <field name="paperformat_id" ref="automotive_parts.paperformat_automotive_label"/>
            <field name="print_report_name">'Automotive Label'</field>
        </record>

        <record id="product.report_product_template_label_dymo" model="ir.actions.report">
            <field name="name">Automotive Label</field>
            <field name="report_name">automotive_parts.report_product_label</field>
            <field name="report_file">automotive_parts.report_product_label</field>
            <field name="paperformat_id" ref="automotive_parts.paperformat_automotive_label"/>
            <field name="print_report_name">'Automotive Label'</field>
        </record>

        <template id="report_product_label">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="label">
                    <div class="page" style="margin: 0; padding: 0; width: 423mm; height: 280mm;">
                        <div style="width: 423mm; height: 280mm; padding: 6mm 10mm 8mm 10mm; box-sizing: border-box; background: #fff; color: #000; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
                            <div style="height: 22mm; text-align: center; font-weight: 500; font-size: 8mm; line-height: 1.05; margin: 0 0 3mm 0; white-space: nowrap; overflow: hidden; text-overflow: clip;">
                                <t t-esc="label.get('denumire')"/>
                            </div>
                            <div style="width: 100%; text-align: center; margin: 0 0 2mm 0;">
                                <t t-if="label.get('barcode')">
                                    <div t-out="label.get('barcode')" t-options="{'widget': 'barcode', 'quiet': 0, 'symbology': 'Code128', 'img_style': 'width:100%;height:70mm;'}"/>
                                </t>
                            </div>
                            <div style="text-align: center; font-weight: 700; font-size: 15mm; line-height: 1; margin: 0 0 20mm 0;">
                                PRET: <t t-esc="format_price(label.get('price'))"/>/BUC
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: flex-end; min-height: 105mm; gap: 12mm;">
                                <div style="flex: 1 1 auto; font-size: 10mm; line-height: 1.45; padding-left: 4mm; padding-bottom: 8mm;">
                                    <div style="margin-bottom: 6mm;">
                                        <strong>Cod Comanda:</strong>
                                        <t t-esc="label.get('product_code') or '-'"/>
                                    </div>
                                    <div>
                                        <strong>Brand:</strong>
                                        <t t-esc="label.get('brand') or '-'"/>
                                    </div>
                                    <div t-if="label.get('internal_code') and label.get('internal_code') != label.get('product_code')" style="font-size: 6mm; margin-top: 6mm;">
                                        <strong>Cod intern:</strong>
                                        <t t-esc="label.get('internal_code')"/>
                                    </div>
                                </div>
                                <div style="flex: 0 0 150mm; min-height: 80mm; text-align: right; padding-right: 4mm; display: flex; align-items: flex-end; justify-content: flex-end;">
                                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Company Logo" style="max-width: 150mm; max-height: 80mm; object-fit: contain;"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
