<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_automotive_async_jobs" model="ir.cron">
        <field name="name">Automotive Async Job Processor</field>
        <field name="model_id" ref="model_automotive_async_job"/>
        <field name="state">code</field>
        <field name="code">model.cron_process_jobs(limit=15)</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
</odoo>
