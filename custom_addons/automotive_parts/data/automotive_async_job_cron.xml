<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_automotive_async_jobs" model="ir.cron">
        <field name="name">Automotive Async Job Processor</field>
        <field name="model_id" ref="model_automotive_async_job"/>
        <field name="state">code</field>
        <field name="code">model.cron_process_jobs()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <function model="ir.config_parameter" name="set_param">
        <value>automotive.async_running_timeout_minutes</value>
        <value>3</value>
    </function>

    <function model="ir.config_parameter" name="set_param">
        <value>automotive.invoice_background_enrichment_enabled</value>
        <value>0</value>
    </function>
</odoo>
