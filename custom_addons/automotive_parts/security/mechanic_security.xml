<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_automotive_portal" model="ir.module.category">
        <field name="name">Automotive Portal</field>
        <field name="sequence">45</field>
    </record>

    <record id="group_mechanic_portal" model="res.groups">
        <field name="name">Mechanic Portal</field>
        <field name="category_id" ref="automotive_parts.module_category_automotive_portal"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="rule_mechanic_portal_sale_order" model="ir.rule">
        <field name="name">Mechanic Portal Sales Orders</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[('mechanic_partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('automotive_parts.group_mechanic_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_mechanic_portal_sale_order_line" model="ir.rule">
        <field name="name">Mechanic Portal Sales Order Lines</field>
        <field name="model_id" ref="sale.model_sale_order_line"/>
        <field name="domain_force">[('order_id.mechanic_partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('automotive_parts.group_mechanic_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_mechanic_portal_request" model="ir.rule">
        <field name="name">Mechanic Portal Requests</field>
        <field name="model_id" ref="model_mechanic_portal_request"/>
        <field name="domain_force">[('partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('automotive_parts.group_mechanic_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_mechanic_portal_payment_allocation" model="ir.rule">
        <field name="name">Mechanic Portal Payment Allocations</field>
        <field name="model_id" ref="model_automotive_payment_allocation"/>
        <field name="domain_force">[('sale_order_id.mechanic_partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('automotive_parts.group_mechanic_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_mechanic_portal_stock_picking" model="ir.rule">
        <field name="name">Mechanic Portal Stock Pickings</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">[('sale_id.mechanic_partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('automotive_parts.group_mechanic_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_mechanic_portal_commercial_document_archive" model="ir.rule">
        <field name="name">Mechanic Portal Commercial Documents</field>
        <field name="model_id" ref="model_commercial_document_archive"/>
        <field name="domain_force">[('state', '=', 'archived'), ('partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('automotive_parts.group_mechanic_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
