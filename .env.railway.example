# Core Odoo
ODOO_ADMIN_PASSWD=replace_with_strong_master_password
ODOO_DB_NAME=odoo_prod
ODOO_DB_USER=replace_with_app_db_user
ODOO_DB_PASSWORD=replace_with_app_db_password
ODOO_LIST_DB=False
ODOO_PROXY_MODE=True
ODOO_WORKERS=0
ODOO_MAX_CRON_THREADS=1

# First deploy only (disable after green boot)
ODOO_INIT_DB=true
ODOO_INIT_MODULES=base,web,automotive_parts
ODOO_AUTO_UPDATE_MODULES=false
ODOO_UPDATE_MODULES=automotive_parts

# Custom module integrations
RAPIDAPI_KEY=replace_me
ANAF_EFACTURA_ENV=test
ANAF_EFACTURA_CUI=12345678
ANAF_OAUTH_CLIENT_ID=replace_me
ANAF_OAUTH_CLIENT_SECRET=replace_me
ANAF_OAUTH_REDIRECT_URI=https://your-domain.example.com/anaf/oauth/callback
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
